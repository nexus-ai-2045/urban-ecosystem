# urban-ecosystem — .dockerignore
# イメージサイズ削減と秘密情報混入防止。
# data/ はイメージ内で RUN 生成するためローカルのものは持ち込まない。

# Git 履歴 (不要・大きい)
.git
.gitignore

# 仮想環境
.venv
venv
dev_env

# テストコード (ランタイム不要)
tests

# 実験・ノートブック (大きい / 不要)
experiments
*.ipynb
.ipynb_checkpoints

# ドキュメント preview は /docs で配信するため Cloud Run image に含める。

# Claude Code / Codex ローカル設定
.claude
.codex
.superpowers

# キャッシュ・コンパイル済みファイル
__pycache__
*.pyc
*.pyo
*.pyd
*.so

# 環境変数ファイル (秘密情報混入防止 — 本番は Secret Manager から注入)
.env
.env.local
.env.*.local
.env.example

# ローカル生成データ (イメージ内で RUN 生成するため不要)
data/

# OS・エディタ
.DS_Store
Thumbs.db
desktop.ini
.vscode
.idea

# ログ・出力
*.log
output/
gcp_results/
